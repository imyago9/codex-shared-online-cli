# Network
PORT=3000

# Access model
# Tailscale Serve is required and configured automatically by npm start.
# The backend always binds to 127.0.0.1.

# Remote desktop sidecar integration (disabled by default)
REMOTE_ENABLED=false
REMOTE_AGENT_URL=http://127.0.0.1:3390
REMOTE_DEFAULT_MODE=view
REMOTE_STREAM_FPS=10
REMOTE_JPEG_QUALITY=62
REMOTE_INPUT_RATE_LIMIT_PER_SEC=120
# Optional max queued remote input events before new events are dropped.
REMOTE_INPUT_MAX_QUEUE=300

# Windows command sidecar client defaults (used from Mac/local automation).
# Keep the sidecar token private; do not commit real values.
# WINDOWS_COMMAND_URL=https://<windows-node>.<tailnet>.ts.net/cmd
# WINDOWS_COMMAND_TOKEN=

# Windows command sidecar server defaults (used on Windows in command-sidecar/).
# COMMAND_SIDECAR_PORT=3777
# COMMAND_SIDECAR_BASE_PATH=/cmd
# COMMAND_SIDECAR_TOKEN=
# COMMAND_SIDECAR_ROOTS=C:\Users\yagof\Projects\codex-shared-online-cli

# Session controls
MAX_SESSIONS=24
SESSION_IDLE_TIMEOUT_MS=2700000
SESSION_SWEEP_INTERVAL_MS=60000
DEFAULT_COLS=120
DEFAULT_ROWS=30
SINGLE_CONSOLE_MODE=false
WS_HEARTBEAT_MS=30000

# Native PowerShell PTY behavior
# PTY_CWD=
# POWERSHELL_COMMAND=powershell.exe
# POWERSHELL_ARGS=-NoLogo

# Persistence and logging
# SESSION_STATE_FILE=.online-cli/sessions-state.json
LOG_LEVEL=info

# Codex index paths (optional)
# CODEX_HOME=~/.codex
# CODEX_SESSIONS_DIR=
# CODEX_HISTORY_FILE=
# CODEX_EXTRA_SESSIONS_DIRS=
